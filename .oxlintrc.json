{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "import",
    "node",
    "typescript",
    "unicorn",
    "oxc"
  ],
  "categories": {
    "correctness": "deny"
  },
  "ignorePatterns": [
    "**/pkg/**",
    "**/web/**",
    "**/bundler/**"
  ],
  "rules": {},
  "env": {
    "builtin": true
  }
}
