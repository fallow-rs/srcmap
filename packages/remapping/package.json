{
  "name": "@srcmap/remapping",
  "version": "0.3.2",
  "description": "Drop-in replacement for @jridgewell/remapping and @ampproject/remapping powered by Rust via WebAssembly",
  "keywords": [
    "composition",
    "concatenation",
    "drop-in",
    "performance",
    "remapping",
    "source-map",
    "sourcemap",
    "wasm",
    "webassembly"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fallow-rs/srcmap.git"
  },
  "files": [
    "src/remapping.mjs",
    "src/remapping.cjs",
    "index.d.ts",
    "README.md"
  ],
  "type": "module",
  "main": "src/remapping.cjs",
  "module": "src/remapping.mjs",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./src/remapping.mjs",
      "require": "./src/remapping.cjs",
      "default": "./src/remapping.mjs"
    }
  },
  "scripts": {
    "test": "node --test __tests__/remapping.test.mjs",
    "test:cjs": "node --test __tests__/remapping.cjs.test.cjs",
    "test:compat": "node --test __tests__/compat.test.mjs"
  },
  "dependencies": {
    "@srcmap/remapping-wasm": "0.3.2"
  },
  "devDependencies": {
    "@jridgewell/remapping": "^2.3.5"
  }
}
