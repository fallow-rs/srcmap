    "build:bundler": "wasm-pack build --target bundler",
    "test": "node --test __tests__/generator-wasm.test.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BartWaardenburg/srcmap.git"
  },
  "keywords": [
    "sourcemap",
    "source-map",
    "generator",
    "builder",
    "rust",
    "wasm",
    "webassembly",
    "performance"
  ]
}
